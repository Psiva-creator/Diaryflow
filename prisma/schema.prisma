// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  pin           String         @default("") // bcrypt-hashed 4-digit PIN
  name          String
  role          String         @default("staff") // "admin" | "staff"
  avatar        String         @default("")
  dairyCode     String         @unique @default(cuid()) // Unique code for staff to join this admin
  adminId       String?        // If this user is staff, points to the admin's id
  admin         User?          @relation("AdminStaff", fields: [adminId], references: [id])
  staff         User[]         @relation("AdminStaff")
  createdAt     DateTime       @default(now())
  notifications Notification[]
  farmers       Farmer[]
  customers     Customer[]
  collections   Collection[]
  payments      Payment[]
  receipts      Receipt[]
  tanks         Tank[]
}

model Farmer {
  id          String       @id @default(cuid())
  displayId   String       // e.g. "F001" — unique per user
  name        String
  village     String
  phone       String
  cattle      Int          @default(1)
  customPricing Boolean    @default(false)
  includesSnf   Boolean    @default(false)
  status      String       @default("active") // "active" | "inactive"
  joinDate    String
  balance     Float        @default(0)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  collections Collection[]
  payments    Payment[]
  receipts    Receipt[]

  @@unique([userId, displayId])
}

model Customer {
  id        String @id @default(cuid())
  displayId String // e.g. "C001" — unique per user
  name      String
  type      String @default("retail") // "retail" | "bulk" | "subscription"
  phone     String
  address   String @default("")
  dailyQty  Float  @default(0)
  status    String @default("active") // "active" | "inactive"
  balance   Float  @default(0)
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  @@unique([userId, displayId])
}

model Collection {
  id         String @id @default(cuid())
  displayId  String // e.g. "MC0001" — unique per user
  farmer     Farmer @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  farmerId   String
  farmerName String
  date       String
  shift      String // "morning" | "evening"
  qty        Float
  fat        Float
  water      Float  @default(0)
  snf        Float?
  rate       Float
  amount     Float
  status     String @default("accepted") // "accepted" | "pending"
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String

  @@unique([userId, displayId])
}

model Payment {
  id         String   @id @default(cuid())
  displayId  String   // e.g. "P001" — unique per user
  farmer     Farmer   @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  farmerId   String
  farmerName String
  amount     Float
  date       String
  method     String // "cash" | "bank" | "upi" | "cheque"
  status     String   @default("pending") // "paid" | "pending"
  note       String   @default("")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  receipts   Receipt[]

  @@unique([userId, displayId])
}

model Receipt {
  id         String  @id @default(cuid())
  displayId  String  // e.g. "R001" — unique per user
  payment    Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  paymentId  String
  farmer     Farmer  @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  farmerId   String
  farmerName String
  amount     Float
  date       String
  paidDate   String
  method     String // "cash" | "bank" | "upi" | "cheque"
  note       String  @default("")
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String

  @@unique([userId, displayId])
}

model Tank {
  id          String @id @default(cuid())
  displayId   String // e.g. "T001" — unique per user
  name        String
  capacity    Float
  current     Float  @default(0)
  temp        Float  @default(4.0)
  status      String @default("operational") // "operational" | "maintenance"
  lastCleaned String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String

  @@unique([userId, displayId])
}

model Notification {
  id     String  @id @default(cuid())
  type   String // "payment" | "collection" | "maintenance"
  msg    String
  time   String
  read   Boolean @default(false)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
}
